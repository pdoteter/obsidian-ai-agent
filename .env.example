# Telegram Bot
TELOXIDE_TOKEN=your_telegram_bot_token_here

# OpenRouter AI (for text classification)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# Obsidian Vault
VAULT_PATH=/path/to/your/obsidian/vault

# Git (optional — set GIT_SYNC_ENABLED=false to disable git sync entirely)
GIT_SYNC_ENABLED=true
GIT_PATH=/path/to/your/git-root-path
GIT_REMOTE_NAME=origin
GIT_BRANCH=main
GIT_SSH_KEY_PATH=
GIT_SYNC_DEBOUNCE_SECS=300

# AI Models (optional)
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=nl
OPENROUTER_MODEL_CLASSIFY=google/gemini-2.5-flash

# Access Control (optional, comma-separated Telegram user IDs)
ALLOWED_USER_IDS=

# Logging
RUST_LOG=info

# Timezone (used for timestamps in daily notes)
TZ=Europe/Brussels
