# Obsidian AI Agent — Configuration
# Copy this file to config.yaml and adjust the values.
# API keys are NOT stored here — they go in .env

# Path to your Obsidian vault
vault_path: /path/to/your/obsidian/vault

# Git sync settings (optional — omit the git section entirely to use defaults)
git:
  sync_enabled: true
  path: /path/to/your/git-root-path      # Required when sync_enabled is true
  remote_name: origin
  branch: main
  ssh_key_path:                           # Leave empty for auto-detection
  sync_debounce_secs: 300                 # Seconds to wait before syncing

# AI model settings (optional — defaults shown)
ai:
  # AI provider: openrouter | gemini (default: openrouter)
  # - openrouter: Requires OPENROUTER_API_KEY in .env
  # - gemini: Requires GEMINI_API_KEY or GEMINI_SERVICE_ACCOUNT_KEY_PATH in .env (Required for PDF transcription)
  provider: openrouter

  # Transcription settings
  whisper_model: whisper-1                # OpenAI Whisper model for transcription
  whisper_language: nl                    # ISO-639-1 language code (e.g. nl, en, de)

  # Classification settings
  # - If provider is openrouter: use OpenRouter model names (e.g. google/gemini-2.5-flash)
  # - If provider is gemini: use native Google model names (e.g. gemini-1.5-flash)
  classify_model: google/gemini-2.5-flash

  # Token limits (optional)
  # max_tokens: 4096                       # Default max output tokens for standard requests (default: 4096)
  # pdf_max_tokens: 8192                   # Default max output tokens for PDF transcription (default: 8192)

# Access control (optional — empty list allows all users)
access:
  allowed_user_ids: []                    # Comma-separated Telegram user IDs, e.g. [123456, 789012]

# Path to custom AI guide (optional)
# guide_path: ./system-guide.md           # Appended to AI prompt for all messages (default: ./system-guide.md)

# Image processing settings (optional — defaults shown)
# image:
#   max_dimension: 1280                   # Max image dimension in pixels (default: 1280)
#   jpeg_quality: 85                      # JPEG compression quality 1-100 (default: 85)
#   assets_folder: assets                 # Folder name for saved images (default: assets)

# URL processing settings (optional — defaults shown)
url:
  transcript_folder: transcripts         # default: transcripts
  fetch_timeout_secs: 15                 # default: 15
  max_content_bytes: 524288              # default: 524288 (512KB)
  max_urls_per_message: 5                # default: 5

# Telegram acknowledgement settings (optional — defaults shown)
# ack:
#   log_mode: reaction                    # reaction | text (default: reaction)
#   log_text: "Done 👍"                   # used when log_mode=text or reaction fallback triggers
#   reaction_emoji: "👍"                  # emoji used for message reaction

# Timezone for timestamps in daily notes (IANA format)
timezone: Europe/Brussels

# Date format for {{date}} in daily note templates (Moment.js syntax, default: YYYY/MM/DD)
date_display_format: YYYY/MM/DD

# Log level (trace, debug, info, warn, error)
log_level: info

# Finance bot settings (optional — defaults shown)
# finance:
#   enabled: false                           # Enable/disable the secondary finance bot (default: false)
#   folder: Finance                          # Subfolder under vault_path to keep position notes (default: Finance)
#   assets_folder: Assets                    # Folder relative to finance.folder to save trade/chart attachments (default: Assets)
#   guide_path: ./finance-system-guide.md    # Path to custom finance AI guide rules (optional, falls back to built-in rules)
#   allowed_user_ids: []                     # Finance bot authorized user IDs (optional, falls back to access.allowed_user_ids if empty)

# WebUI Portal settings (optional — defaults shown)
webui:
  enabled: true                            # Enable/disable the secure companion WebUI (default: true)
  port: 3000                               # Local port to host the WebUI server (default: 3000)
