# Container environment variables for Docker deployment
# Copy this file to .env.docker and fill in the values.
# These paths are CONTAINER-INTERNAL (not your host paths).

# Telegram Bot
TELOXIDE_TOKEN=your_telegram_bot_token_here

# OpenRouter AI (for text classification)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# Obsidian Vault (container-internal paths)
# HOST_VAULT_PATH (in .env) mounts the git repo root at /app/vault
# Set VAULT_PATH to the vault subdirectory within the git repo
# Example: if your git repo is ~/obsidian and vault is ~/obsidian/MyVault
#   .env:        HOST_VAULT_PATH=~/obsidian
#   .env.docker: VAULT_PATH=/app/vault/MyVault
VAULT_PATH=/app/vault/MyVault

# Git
GIT_SYNC_ENABLED=true
GIT_PATH=/app/vault
GIT_REMOTE_NAME=origin
GIT_BRANCH=main
GIT_SSH_KEY_PATH=/home/botuser/.ssh/id_rsa
GIT_SYNC_DEBOUNCE_SECS=300

# AI Models
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=nl
OPENROUTER_MODEL_CLASSIFY=google/gemini-2.5-flash

# Access Control (optional, comma-separated Telegram user IDs)
ALLOWED_USER_IDS=

# Logging
RUST_LOG=info
