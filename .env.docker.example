# API Keys (secrets only — all other settings go in config.yaml)
# Copy this file to .env.docker and fill in the values.

# Telegram Bot
TELOXIDE_TOKEN=your_telegram_bot_token_here
# FINANCE_TELOXIDE_TOKEN=your_finance_telegram_bot_token_here # Optional: required only if finance bot is enabled

# OpenRouter AI (for text classification)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# WebUI Access Passcode (required if WebUI is enabled)
WEBUI_AUTH_TOKEN=your_secure_webui_passcode_here
